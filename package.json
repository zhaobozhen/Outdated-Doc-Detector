{
  "name": "outdated-doc-detector",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A quiet freshness detector for localized developer documentation.",
  "engines": {
    "node": ">=26.5.0"
  },
  "scripts": {
    "dev": "wxt",
    "prepare": "wxt prepare",
    "build": "wxt build",
    "build:e2e": "wxt build --mode test",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:update": "npm run build:e2e && playwright test --update-snapshots=all"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/chrome": "0.2.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "@wxt-dev/module-react": "1.2.2",
    "jsdom": "29.1.1",
    "lucide-static": "1.24.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vite": "6.4.3",
    "vite-node": "3.2.4",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  }
}
